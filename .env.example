# ---- Talks Player configuration ----

# The Google Drive folder that holds your talks (the long string in the folder URL:
# https://drive.google.com/drive/folders/THIS_PART )
DRIVE_FOLDER_ID=

# The full service-account JSON key, on ONE line (paste the whole { ... } contents).
# Create it in Google Cloud Console > IAM > Service Accounts > Keys > Add key (JSON),
# then SHARE the Drive folder above with the service account's client_email.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Shared access code your team types to get in. Leave blank to make the app open.
APP_PASSCODE=

# Name shown in the app header / lock screen.
APP_TITLE=Talks

# Secret used to sign the login cookie. Set to any long random string in production.
SESSION_SECRET=

# Port (Render sets this automatically).
PORT=3000
